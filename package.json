{
    "name": "shamela-epub-exporter",
    "description": "Export Shamela books to EPUB locally in your browser.",
    "private": true,
    "version": "1.2.1",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/yshalsager/shamela-epub-exporter.git"
    },
    "license": "GPL-3.0-only",
    "author": {
        "name": "yshalsager",
        "email": "contact@yshalsager.com"
    },
    "type": "module",
    "scripts": {
        "dev": "wxt",
        "dev:firefox": "wxt -b firefox",
        "build": "wxt build",
        "build:firefox": "wxt build -b firefox",
        "zip": "wxt zip",
        "zip:firefox": "wxt zip -b firefox",
        "test": "vitest",
        "wuchale": "wuchale",
        "wxt": "wxt",
        "check": "svelte-check --tsconfig ./tsconfig.json",
        "format": "prettier --write .",
        "lint": "prettier --check . && eslint .",
        "lint:fix": "prettier --write . && eslint . --fix",
        "postinstall": "wxt prepare",
        "tauri": "tauri",
        "tauri:dev": "vite --config vite.config.ts",
        "tauri:build": "vite build --config vite.config.ts",
        "desktop": "tauri dev",
        "desktop:build": "tauri build"
    },
    "devDependencies": {
        "@eslint/css": "^1.1.0",
        "@eslint/js": "^10.0.1",
        "@eslint/json": "^1.2.0",
        "@eslint/markdown": "^8.0.1",
        "@internationalized/date": "^3.12.0",
        "@lucide/svelte": "^1.7.0",
        "@sveltejs/vite-plugin-svelte": "^7.0.0",
        "@tailwindcss/forms": "^0.5.11",
        "@tailwindcss/typography": "^0.5.19",
        "@tailwindcss/vite": "^4.2.2",
        "@tauri-apps/api": "^2.10.1",
        "@tauri-apps/cli": "^2.10.1",
        "@tauri-apps/plugin-dialog": "^2.7.0",
        "@tauri-apps/plugin-fs": "^2.5.0",
        "@tauri-apps/plugin-notification": "^2.3.3",
        "@tauri-apps/plugin-store": "^2.4.2",
        "@tsconfig/svelte": "^5.0.8",
        "@wuchale/svelte": "^0.19.3",
        "@wxt-dev/auto-icons": "^1.1.1",
        "@wxt-dev/module-svelte": "^2.0.5",
        "bits-ui": "^2.17.0",
        "buffer": "^6.0.3",
        "clsx": "^2.1.1",
        "eslint": "^10.2.0",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-import-x": "^4.16.2",
        "eslint-plugin-simple-import-sort": "^12.1.1",
        "eslint-plugin-svelte": "^3.17.0",
        "globals": "^17.4.0",
        "jszip": "^3.10.1",
        "mdb-reader": "^3.2.0",
        "mode-watcher": "^1.1.0",
        "pdfmake-rtl": "^2.1.2",
        "playwright": "^1.59.1",
        "prettier": "3.8.1",
        "prettier-plugin-svelte": "^3.5.1",
        "prettier-plugin-tailwindcss": "^0.7.2",
        "publish-browser-extension": "^4.0.4",
        "svelte": "^5.55.1",
        "svelte-check": "^4.4.6",
        "tailwind-merge": "^3.5.0",
        "tailwind-variants": "^3.2.2",
        "tailwindcss": "^4.2.2",
        "tslib": "^2.8.1",
        "tw-animate-css": "^1.4.0",
        "typescript": "^6.0.2",
        "typescript-eslint": "^8.58.0",
        "vite": "^8.0.3",
        "vite-plugin-node-polyfills": "^0.26.0",
        "vitest": "^4.1.2",
        "wuchale": "^0.22.8",
        "wxt": "^0.20.20"
    }
}
